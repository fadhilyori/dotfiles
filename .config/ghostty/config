# Cell and spacing adjustments
adjust-cell-height = 35%

# Theme: Catppuccin Mocha (custom implementation)
# Replaces Atom theme for better contrast and modern aesthetics
foreground = #CDD6F4
background = #1E1E2E
cursor-color = #F5E0DC
cursor-text = #1E1E2E
selection-foreground = #1E1E2E
selection-background = #F5E0DC

# Catppuccin Mocha color palette
palette = 0=#45475A
palette = 8=#585B70
palette = 1=#F38BA8
palette = 9=#F38BA8
palette = 2=#A6E3A1
palette = 10=#A6E3A1
palette = 3=#F9E2AF
palette = 11=#F9E2AF
palette = 4=#89B4FA
palette = 12=#89B4FA
palette = 5=#F5C2E7
palette = 13=#F5C2E7
palette = 6=#94E2D5
palette = 14=#94E2D5
palette = 7=#BAC2DE
palette = 15=#A6ADC8

# Background and window effects
background-opacity = 0.85
background-blur = true

# Quick terminal configuration
quick-terminal-position = top
quick-terminal-size = 30%,80%

# Window configuration
window-height = 24
window-width = 120
window-decoration = client
window-padding-balance = true
window-padding-x = 5
window-padding-y = 0
window-save-state = always
undo-timeout = 10s

# Font configuration
font-family = "JetBrains Mono"
font-size = 10
font-feature = +calt

# Link and mouse settings
link-url = true
link-previews = true
mouse-hide-while-typing = true
mouse-scroll-multiplier = 2

# Cursor configuration
cursor-style = underline
cursor-style-blink = true

# Selection and clipboard improvements
selection-clear-on-typing = true
right-click-action = copy

# Bell configuration (visual feedback only)
bell-features = no-system,no-audio,attention,title

# Shell integration with SSH improvements
shell-integration-features = no-cursor,sudo,title,ssh-env,ssh-terminfo

# Command Palette (Ghostty 1.2.0)
# Available via ctrl+shift+p on GTK by default

# === KEYBINDINGS ===

# Global keybinds
keybind = global:ctrl+grave_accent=toggle_quick_terminal

# Font size control
keybind = ctrl+plus=set_font_size:+1
keybind = ctrl+minus=set_font_size:-1
keybind = ctrl+0=set_font_size:10

# Split management (existing, enhanced)
keybind = shift+ctrl+\=new_split:right
keybind = shift+ctrl+-=new_split:down
keybind = shift+ctrl+j=goto_split:bottom
keybind = shift+ctrl+k=goto_split:top
keybind = shift+ctrl+h=goto_split:left
keybind = shift+ctrl+l=goto_split:right
keybind = shift+ctrl+z=toggle_split_zoom
keybind = shift+ctrl+e=equalize_splits

# Tab management
keybind = ctrl+shift+t=new_tab
keybind = ctrl+shift+w=close_tab
keybind = ctrl+tab=next_tab
keybind = ctrl+shift+tab=previous_tab

# Window management
keybind = ctrl+shift+n=new_window
keybind = ctrl+shift+q=close_window

# Selection and clipboard
keybind = ctrl+shift+c=copy_to_clipboard
keybind = ctrl+shift+v=paste_from_clipboard
keybind = ctrl+shift+f=scroll_to_selection
keybind = performable:ctrl+c=copy_to_clipboard

# Text input
keybind = shift+enter=text:\n
