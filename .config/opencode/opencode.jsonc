{
    "$schema": "https://opencode.ai/config.json",
    "instructions": [
        "CONTRIBUTING.md"
    ],
    "plugin": [
        "opencode-wakatime",
        "context-mode"
    ],
    "autoupdate": true,
    "share": "disabled",
    "default_agent": "plan",
    "model": "personal/MiniMax-M3",
    "small_model": "personal/MiniMax-M3",
    "disabled_providers": [],
    "experimental": {
        "disable_paste_summary": true
    },
    "provider": {
        "personal": {
            "npm": "@ai-sdk/anthropic",
            "name": "Personal",
            "options": {
                "baseURL": "{env:PERSONAL_BASE_URL}/anthropic/v1",
                "apiKey": "{env:PERSONAL_API_KEY}"
            },
            "models": {
                "MiniMax-M2.7": {
                    "name": "MiniMax M2.7",
                    "family": "minimax",
                    "provider": {
                        "npm": "@ai-sdk/anthropic",
                    },
                    "headers": {
                        // true: disable content logging, default: content logging is disabled
                        "x-bf-disable-content-logging": "false"
                    },
                    "modalities": {
                        "input": [
                            "text"
                        ],
                        "output": [
                            "text"
                        ]
                    },
                    "limit": {
                        "context": 204800,
                        "output": 131072
                    },
                    "cost": {
                        "input": 0.30,
                        "output": 1.20,
                        "cache_read": 0.06,
                        "cache_write": 0.375
                    },
                    "temperature": true,
                    "reasoning": true,
                    "tool_call": true,
                    "release_date": "2026-03-18"
                },
                "MiniMax-M2.7-highspeed": {
                    "name": "MiniMax M2.7 High Speed",
                    "family": "minimax",
                    "provider": {
                        "npm": "@ai-sdk/anthropic"
                    },
                    "headers": {
                        "x-bf-disable-content-logging": "false"
                    },
                    "modalities": {
                        "input": [
                            "text"
                        ],
                        "output": [
                            "text"
                        ]
                    },
                    "limit": {
                        "context": 204800,
                        "output": 131072
                    },
                    "cost": {
                        "input": 0.60,
                        "output": 2.40,
                        "cache_read": 0.06,
                        "cache_write": 0.375
                    },
                    "temperature": true,
                    "reasoning": true,
                    "tool_call": true,
                    "release_date": "2026-03-18"
                },
                "MiniMax-M3": {
                    "name": "MiniMax M3",
                    "family": "minimax",
                    "provider": {
                        "npm": "@ai-sdk/anthropic"
                    },
                    "headers": {
                        "x-bf-disable-content-logging": "false"
                    },
                    "modalities": {
                        "input": [
                            "text",
                            "image",
                            "video"
                        ],
                        "output": [
                            "text"
                        ]
                    },
                    "limit": {
                        "context": 1000000,
                        "output": 128000
                    },
                    "cost": {
                        "input": 0.30,
                        "output": 1.20,
                        "cache_read": 0.06
                    },
                    "temperature": true,
                    "reasoning": true,
                    "attachment": true,
                    "tool_call": true,
                    "release_date": "2026-06-01",
                    "variants": {
                        "none": {
                            "thinking": {
                                "type": "disabled"
                            }
                        },
                        "thinking": {
                            "thinking": {
                                "type": "adaptive"
                            }
                        }
                    }
                }
            }
        },
        "personal-openai": {
            "npm": "@ai-sdk/openai-compatible",
            "name": "Personal",
            "options": {
                "baseURL": "{env:PERSONAL_BASE_URL}/v1",
                "apiKey": "{env:PERSONAL_API_KEY}"
            },
            "models": {
                "glm-5.2": {
                    "name": "GLM-5.2",
                    "family": "glm",
                    "provider": {
                        "npm": "@ai-sdk/openai-compatible",
                    },
                    "headers": {
                        "x-bf-disable-content-logging": "false"
                    },
                    "modalities": {
                        "input": [
                            "text"
                        ],
                        "output": [
                            "text"
                        ]
                    },
                    "limit": {
                        "context": 1000000,
                        "output": 131072
                    },
                    "cost": {
                        "input": 0.60,
                        "output": 2.20,
                        "cache_read": 0.11
                    },
                    "temperature": true,
                    "reasoning": true,
                    "attachment": false,
                    "tool_call": true,
                    "release_date": "2026-06-13",
                    "interleaved": {
                        "field": "reasoning_content"
                    },
                    "variants": {
                        "high": {
                            "reasoningEffort": "high"
                        },
                        "max": {
                            "reasoningEffort": "max"
                        }
                    }
                },
                "glm-4.7": {
                    "name": "GLM-4.7",
                    "family": "glm",
                    "provider": {
                        "npm": "@ai-sdk/openai-compatible",
                    },
                    "headers": {
                        "x-bf-disable-content-logging": "false"
                    },
                    "modalities": {
                        "input": [
                            "text"
                        ],
                        "output": [
                            "text"
                        ]
                    },
                    "limit": {
                        "context": 204800,
                        "output": 131072
                    },
                    "cost": {
                        "input": 1.40,
                        "output": 4.40,
                        "cache_read": 0.26
                    },
                    "temperature": true,
                    "reasoning": true,
                    "attachment": false,
                    "tool_call": true,
                    "release_date": "2025-12-22",
                    "interleaved": {
                        "field": "reasoning_content"
                    },
                    "variants": {}
                }
            }
        },
        "work": {
            "npm": "@ai-sdk/openai-compatible",
            "name": "Work",
            "options": {
                "baseURL": "{env:PERSONAL_BASE_URL}/v1",
                "apiKey": "{env:PERSONAL_API_KEY}"
            },
            "models": {
                "deepseek-v4-flash": {
                    "name": "DeepSeek V4 Flash",
                    "family": "deepseek-flash",
                    "headers": {
                        "x-bf-disable-content-logging": "true"
                    },
                    "provider": {
                        "npm": "@ai-sdk/openai-compatible"
                    },
                    "modalities": {
                        "input": [
                            "text"
                        ],
                        "output": [
                            "text"
                        ]
                    },
                    "limit": {
                        "context": 1000000,
                        "output": 384000
                    },
                    "cost": {
                        "input": 0.14,
                        "output": 0.28,
                        "cache_read": 0.0028,
                        "cache_write": 0
                    },
                    "temperature": true,
                    "reasoning": true,
                    "attachment": false,
                    "tool_call": true,
                    "release_date": "2026-04-24",
                    "interleaved": {
                        "field": "reasoning_content"
                    },
                    "variants": {
                        "low": {
                            "reasoningEffort": "low"
                        },
                        "medium": {
                            "reasoningEffort": "medium"
                        },
                        "high": {
                            "reasoningEffort": "high"
                        },
                        "max": {
                            "reasoningEffort": "max"
                        }
                    }
                },
                "deepseek-v4-pro": {
                    "name": "DeepSeek V4 Pro",
                    "family": "deepseek-thinking",
                    "headers": {
                        "x-bf-disable-content-logging": "true"
                    },
                    "provider": {
                        "npm": "@ai-sdk/openai-compatible"
                    },
                    "modalities": {
                        "input": [
                            "text"
                        ],
                        "output": [
                            "text"
                        ]
                    },
                    "limit": {
                        "context": 1000000,
                        "output": 384000
                    },
                    "cost": {
                        "input": 0.435,
                        "output": 0.87,
                        "cache_read": 0.003625,
                        "cache_write": 0
                    },
                    "temperature": true,
                    "reasoning": true,
                    "attachment": false,
                    "tool_call": true,
                    "release_date": "2026-04-24",
                    "interleaved": {
                        "field": "reasoning_content"
                    },
                    "variants": {
                        "low": {
                            "reasoningEffort": "low"
                        },
                        "medium": {
                            "reasoningEffort": "medium"
                        },
                        "high": {
                            "reasoningEffort": "high"
                        },
                        "max": {
                            "reasoningEffort": "max"
                        }
                    }
                }
            }
        }
    },
    "mcp": {
        "mcp-gateway": {
            "enabled": true,
            "type": "remote",
            "url": "{env:PERSONAL_BASE_URL}/mcp",
            "headers": {
                "x-bf-vk": "{env:PERSONAL_API_KEY}"
            }
        },
        "playwright": {
            "enabled": false,
            "type": "local",
            "command": [
                "npx",
                "@playwright/mcp@latest"
            ]
        },
        "codegraph": {
            "enabled": true,
            "type": "local",
            "command": [
                "codegraph",
                "serve",
                "--mcp"
            ]
        }
    },
    "lsp": {
        "markdown": {
            "command": [
                "marksman",
                "server"
            ],
            "extensions": [
                ".md",
                ".mdx"
            ]
        }
    },
    "compaction": {
        "auto": true
    },
    "agent": {
        "build": {
            "model": "personal-openai/glm-5.2"
        },
        "plan": {
            "model": "personal/MiniMax-M3"
        },
        "explore": {
            "model": "personal/MiniMax-M3"
        },
        "compaction": {
            "model": "personal/MiniMax-M3"
        },
        "summary": {
            "model": "personal/MiniMax-M3"
        },
        "title": {
            "model": "personal/MiniMax-M3"
        }
    }
}
