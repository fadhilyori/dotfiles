// Zed settings
//
{
    "cli_default_open_behavior": "new_window",
    "terminal": {
        "flexible": true,
        "dock": "bottom",
        "show_count_badge": true
    },
    "outline_panel": {
        "dock": "left"
    },
    "collaboration_panel": {
        "dock": "left"
    },
    "git_panel": {
        "dock": "right",
        "sort_by_path": true,
        "tree_view": true
    },
    "prettier": {
        "allowed": true
    },
    "format_on_save": "off",
    "preferred_line_length": 130,
    "restore_on_startup": "launchpad",
    "icon_theme": {
        "mode": "system",
        "light": "Zed (Default)",
        "dark": "Zed (Default)"
    },
    "theme": {
        "mode": "system",
        "light": "Catppuccin Latte",
        "dark": "Catppuccin Mocha"
    },
    "ui_font_family": ".SystemUIFont",
    "ui_font_size": 14,
    "buffer_font_family": "JetBrainsMono Nerd Font",
    "buffer_font_size": 14.0,
    "buffer_font_weight": 300,
    "buffer_line_height": {
        "custom": 1.6
    },
    "soft_wrap": "bounded",
    "telemetry": {
        "diagnostics": false,
        "metrics": false
    },
    "session": {
        "trust_all_worktrees": true
    },
    "buffer_font_features": {
        "calt": false
    },
    "tabs": {
        "file_icons": true,
        "git_status": true
    },
    "tab_bar": {
        "show": true
    },
    "file_types": {
        "HAProxy": ["haproxy.cfg"]
    },
    "git": {
        "gutter_debounce": 30,
        "inline_blame": {
            "delay_ms": 200,
            "enabled": true,
            "show_commit_summary": true
        }
    },
    "title_bar": {
        "show_menus": false,
        "show_sign_in": true,
        "show_branch_status_icon": true,
        "button_layout": "standard"
    },
    "project_panel": {
        "dock": "left",
        "bold_folder_labels": false,
        "folder_icons": true,
        "file_icons": true,
        "hide_gitignore": false,
        "entry_spacing": "standard"
    },
    "disable_ai": false,
    "vim_mode": false,
    "use_podman": true,
    "relative_line_numbers": "disabled",
    "agent_servers": {
        "OpenCode": {
            "command": "~/.opencode/bin/opencode",
            "args": ["acp"],
            "type": "custom"
        }
    },
    "language_models": {
        "anthropic": {
            "api_url": "https://api.minimax.io/anthropic",
            "available_models": [
                {
                    "name": "MiniMax-M2.7",
                    "max_tokens": 204800,
                    "max_output_tokens": 131072
                },
                {
                    "name": "MiniMax-M2.5",
                    "max_tokens": 204800,
                    "max_output_tokens": 131072
                }
            ]
        },
        "openai_compatible": {
            "OpenCode Go": {
                "api_url": "https://opencode.ai/zen/go",
                "available_models": [
                    {
                        "name": "kimi-k2.5",
                        "max_tokens": 262144,
                        "max_output_tokens": 65536,
                        "display_name": "Kimi K2.5",
                        "capabilities": {
                            "tools": true,
                            "images": true,
                            "parallel_tool_calls": true,
                            "prompt_cache_key": false,
                            "chat_completions": true
                        }
                    },
                    {
                        "name": "glm-5",
                        "max_tokens": 204800,
                        "max_output_tokens": 131072,
                        "display_name": "GLM-5",
                        "capabilities": {
                            "tools": true,
                            "images": false,
                            "parallel_tool_calls": true,
                            "prompt_cache_key": false,
                            "chat_completions": true
                        }
                    }
                ]
            }
        }
    },
    "edit_predictions": {
        "mode": "subtle",
        "provider": "zed"
    },
    "agent": {
        "dock": "right",
        "show_turn_stats": true,
        "single_file_review": true,
        "default_profile": "ask",
        "default_model": {
            "provider": "anthropic",
            "model": "MiniMax-M2.7",
            "enable_thinking": true
        },
        "commit_message_model": {
            "provider": "anthropic",
            "model": "MiniMax-M2.7",
            "enable_thinking": false
        },
        "favorite_models": [
            {
                "provider": "anthropic",
                "model": "MiniMax-M2.7",
                "enable_thinking": true
            }
        ],
        "play_sound_when_agent_done": "always",
        "model_parameters": []
    },
    "hard_tabs": false,
    "tab_size": 4,
    "base_keymap": "VSCode",
    "current_line_highlight": "none",
    "autosave": {
        "after_delay": {
            "milliseconds": 2000
        }
    },
    "cursor_shape": "bar",
    "languages": {
        "YAML": {
            "tab_size": 2,
            "hard_tabs": false
        },
        "Nginx": {
            "format_on_save": "on"
        },
        "Python": {
            "code_actions_on_format": {
                "source.organizeImports.ruff": true
            },
            "formatter": {
                "language_server": {
                    "name": "ruff"
                }
            },
            "language_servers": [
                // Disable basedpyright and enable ty, and otherwise
                // use the default configuration.
                "ty",
                "!basedpyright",
                "..."
            ]
        },
        "Shell Script": {
            "tab_size": 4,
            "hard_tabs": false,
            "format_on_save": "on",
            "formatter": {
                "external": {
                    "command": "shfmt",
                    "arguments": ["--filename", "{buffer_path}", "--indent", "4"]
                }
            }
        },
        "PHP": {
            "language_servers": ["phpactor", "!intelephense", "!phptools", "..."]
        },
        "TypeScript": {
            "tab_size": 2
        }
    },
    "lsp": {
        "tailwindcss-language-server": {
            "settings": {
                "includeLanguages": {
                    "php": "html",
                    "blade": "html"
                },
                "experimental": {
                    "classRegex": [
                        "class=\"([^\"]*)\"",
                        "class='([^']*)'",
                        "class=\\\"([^\\\"]*)\\\"",
                        "@class\\(\\[([^\\]]*)\\]\\)"
                    ]
                }
            }
        }
    }
}
