{
  "lastChangelogVersion": "0.80.10",
  "theme": "catppuccin-tui-latte/catppuccin-tui-mocha",
  "defaultProvider": "personal",
  "defaultModel": "MiniMax-M3",
  "terminal": {
    "showTerminalProgress": true
  },
  "enableInstallTelemetry": false,
  "defaultProjectTrust": "always",
  "defaultThinkingLevel": "high",
  "images": {
    "blockImages": false
  },
  "packages": [
    "npm:@firstpick/pi-themes-bundle",
    "npm:context-mode",
    "npm:pi-mcp-adapter",
    "npm:@juicesharp/rpiv-todo",
    "npm:@juicesharp/rpiv-ask-user-question",
    "npm:@juicesharp/rpiv-advisor",
    "npm:pi-bar",
    "npm:pi-intercom",
    "npm:pi-prompt-template-model",
    "npm:@vndv/pi-codegraph",
    "npm:@upstash/context7-pi",
    "npm:pi-catppuccin-tui",
    "npm:@devkade/pi-plan",
    "npm:pi-simplify",
    "npm:@juicesharp/rpiv-pi",
    "npm:@tintinweb/pi-subagents",
    "npm:@juicesharp/rpiv-i18n",
    "npm:@juicesharp/rpiv-web-tools",
    "npm:@juicesharp/rpiv-args",
    "npm:@juicesharp/rpiv-workflow",
    "npm:pi-autoresearch",
    "npm:@plannotator/pi-extension"
  ],
  "showHardwareCursor": false,
  "editorPaddingX": 0,
  "followUpMode": "all",
  "steeringMode": "all",
  "transport": "auto",
  "hideThinkingBlock": true,
  "quietStartup": true
}